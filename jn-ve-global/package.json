{
    "name": "jn-ve-global",
    "version": "3.6.10",
    "author": "zyc",
    "type": "module",
    "description": "基于 vue3+element-plus+ts 的二次封装库 -- 江苏金农内部库",
    "files": [
        "dist",
        "es",
        "lib",
        "packages"
    ],
    "main": "lib/index.js",
    "module": "es/index.mjs",
    "types": "es/index.d.ts",
    "exports": {
        ".": {
            "types": "./es/index.d.ts",
            "import": "./es/index.mjs",
            "require": "./lib/index.js"
        },
        "./global": {
            "types": "./es/global.d.ts"
        },
        "./es": {
            "types": "./es/index.d.ts",
            "import": "./es/index.mjs"
        },
        "./lib": {
            "types": "./lib/index.d.ts",
            "require": "./lib/index.js"
        },
        "./es/*.mjs": {
            "types": "./es/*.d.ts",
            "import": "./es/*.mjs"
        },
        "./lib/*.js": {
            "types": "./lib/*.d.ts",
            "require": "./lib/*.js"
        },
        "./packages/*": {
            "types": "./packages/index.ts",
            "import": "./packages/*"
        },
        "./*": "./*"
    },
    "scripts": {
        "build": "gulp --require @esbuild-kit/cjs-loader -f scripts/build/index.ts",
        "build:vite": "vite build",
        "build:px": "pnpm build --px"
    },
    "sideEffects": [
        "dist/*",
        "es/**/*.css",
        "lib/**/*.scss",
        "es/**/style/*",
        "lib/**/style/*"
    ],
    "publishConfig": {
        "registry": "http://172.31.71.159/repository/npm-jsjngf/"
    }
}
