{
    "name": "jn-ve-global",
    "version": "3.4.0",
    "author": "zyc",
    "type": "module",
    "description": "基于 vue3+element-plus+ts 的二次封装库 -- 江苏金农内部库",
    "files": [
        "dist",
        "es",
        "lib",
        "packages"
    ],
    "main": "lib/index.js",
    "module": "es/index.mjs",
    "types": "es/index.d.ts",
    "exports": {
        ".": {
            "types": "./es/index.d.ts",
            "import": "./es/index.mjs",
            "require": "./lib/index.js"
        },
        "./global": {
            "types": "./es/global.d.ts"
        },
        "./es": {
            "types": "./es/index.d.ts",
            "import": "./es/index.mjs"
        },
        "./lib": {
            "types": "./lib/index.d.ts",
            "require": "./lib/index.js"
        },
        "./es/*.mjs": {
            "types": "./es/*.d.ts",
            "import": "./es/*.mjs"
        },
        "./lib/*.js": {
            "types": "./lib/*.d.ts",
            "require": "./lib/*.js"
        },
        "./*": "./*"
    },
    "scripts": {
        "build": "gulp --require @esbuild-kit/cjs-loader -f scripts/build/index.ts",
        "build:vite": "vite build",
        "build:px": "pnpm build --px"
    },
    "devDependencies": {
        "@esbuild-kit/cjs-loader": "^2.4.4",
        "@rollup/plugin-commonjs": "^25.0.7",
        "@rollup/plugin-image": "^3.0.3",
        "@rollup/plugin-json": "^6.0.1",
        "@rollup/plugin-node-resolve": "^15.2.3",
        "@rollup/plugin-url": "^8.0.2",
        "@rollup/pluginutils": "^5.0.5",
        "@types/gulp": "^4.0.16",
        "@vitejs/plugin-vue": "^4.0.0",
        "@vitejs/plugin-vue-jsx": "^3.0.0",
        "autoprefixer": "^10.4.16",
        "clean-css": "^5.3.2",
        "cssnano": "^6.0.1",
        "esbuild": "^0.19.5",
        "execa": "^8.0.1",
        "fast-glob": "^3.3.1",
        "fs-extra": "^11.1.1",
        "generate-source-map": "^0.0.5",
        "gulp": "^4.0.2",
        "postcss-pxtorem": "^6.0.0",
        "postcss-selector-not": "^6.0.1",
        "rollup": "^4.3.0",
        "rollup-plugin-copy": "^3.5.0",
        "rollup-plugin-esbuild": "^6.1.0",
        "rollup-plugin-postcss": "^4.0.2",
        "rollup-plugin-string": "^3.0.0",
        "sass": "^1.51.0",
        "unplugin-vue-define-options": "^1.3.18",
        "vue-tsc": "^1.8.19"
    },
    "sideEffects": [
        "dist/*",
        "es/**/*.css",
        "lib/**/*.scss",
        "es/**/style/*",
        "lib/**/style/*"
    ],
    "publishConfig": {
        "registry": "http://172.31.71.159/repository/npm-release/"
    }
}
