{
    "name": "@jsjn/utils",
    "author": "zyc",
    "version": "1.6.2",
    "type": "module",
    "files": [
        "dist",
        "@types",
        "src/utils"
    ],
    "main": "./dist/index.umd.cjs",
    "module": "./dist/index.js",
    "types": "./@types/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "require": "./dist/index.umd.cjs"
        },
        "./dist/*": "./dist/*",
        "./@types/*": "./@types/*",
        "./utils/*": "./src/utils/*"
    },
    "scripts": {
        "build": "vue-tsc --noEmit && vite build",
        "build:push": "vue-tsc --noEmit && vite build && yalc push --private && npm publish"
    },
    "dependencies": {
        "lodash": "^4.17.21"
    },
    "devDependencies": {
        "@types/lodash": "^4.14.185",
        "typescript": "^4.6.4",
        "vite": "4.2.1",
        "vite-plugin-dts": "^1.5.0",
        "vue-tsc": "^1.2.0",
        "yalc": "1.0.0-pre.53"
    },
    "publishConfig": {
        "registry": "http://172.31.71.159/repository/npm-release/"
    }
}
